# Core database (use a development database locally; never production)
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"
DIRECT_DATABASE_URL="postgresql://user:password@host/database?sslmode=require"

# Clerk authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
CLERK_WEBHOOK_SECRET="whsec_..."

# AI and observability
OPENROUTER_API_KEY="sk-or-..."
TAVILY_API_KEY="tvly-..."
POSTHOG_API_KEY="phc_..."
NEXT_PUBLIC_POSTHOG_KEY="phc_..."
NEXT_PUBLIC_POSTHOG_HOST="https://<your-posthog-host>"

# Public URLs
NEXT_PUBLIC_APP_URL="http://localhost:3000"
APP_URL="http://localhost:3000"

# Uploads and RAG source-file storage
BLOB_READ_WRITE_TOKEN=""

# Background maintenance (Upstash QStash + cron authorization)
QSTASH_URL="https://qstash.upstash.io/v2"
QSTASH_TOKEN=""
QSTASH_CURRENT_SIGNING_KEY=""
QSTASH_NEXT_SIGNING_KEY=""
CRON_SECRET="replace-with-a-long-random-value"

# Voice output (ElevenLabs)
ELEVENLABS_API_KEY=""
ELEVENLABS_VOICE_ID=""
# Set from the effective ElevenLabs plan price; used for estimated cost tracking.
ELEVENLABS_COST_PER_1000_CHARS_USD=""

# Telegram
TELEGRAM_BOT_TOKEN=""
TELEGRAM_BOT_USERNAME=""
TELEGRAM_WEBHOOK_SECRET=""
TELEGRAM_SYNC_WEBHOOK="false"
TELEGRAM_DISABLE_AI="false"
TELEGRAM_DISABLE_SEND="false"

# WhatsApp Cloud API
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_APP_SECRET=""
WHATSAPP_VERIFY_TOKEN=""
WHATSAPP_SYNC_WEBHOOK="false"
WHATSAPP_DISABLE_AI="false"
WHATSAPP_DISABLE_SEND="false"

# Integration tests (must be an isolated, disposable database)
TEST_DATABASE_URL=""

# Optional diagnostics
LOG_PRISMA_QUERIES="false"
ENABLE_LATENCY_LOGS="false"
APP_LOG_LEVEL=""
APP_LOG_FORMAT=""
APP_LOG_COLORS=""
APP_LOG_DOMAIN_LEVELS=""
APP_LOG_EXCLUDE_EVENTS=""
