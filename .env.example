# -----------------------------------------------------
# Core
# -----------------------------------------------------
DATABASE_URL="postgresql://user:password@localhost:5432/anthon?schema=public"
DIRECT_DATABASE_URL="postgresql://user:password@localhost:5432/anthon?schema=public"

# Ephemeral integration-test branch management. TEST_DATABASE_URL is created
# by the test runner and must not be stored in an env file.
NEON_API_KEY=""
NEON_PROJECT_ID=""

# Public app URLs
APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional fallback used in some webhook link generation
VERCEL_URL=""

# -----------------------------------------------------
# Clerk
# -----------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
CLERK_WEBHOOK_SECRET="whsec_..."

# -----------------------------------------------------
# OpenRouter (AI)
# -----------------------------------------------------
OPENROUTER_API_KEY="sk-or-..."

# Turn planner: set to legacy only for an immediate behavioral rollback.
AI_TURN_PLANNER_MODE="v2"

# Base64-encoded 32-byte AES-256-GCM key for encrypted AI debug traces.
AI_TRACE_ENCRYPTION_KEY=""

# Optional web-search tool for AI
TINYFISH_API_KEY=""
TAVILY_API_KEY="tvly-..."

# -----------------------------------------------------
# Vercel Blob (general uploads)
# -----------------------------------------------------
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# Dedicated private Blob store for generated web voice. This must be the
# read/write token for a store created with access=private; do not reuse the
# general/public upload-store token above.
VOICE_BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# -----------------------------------------------------
# QStash (maintenance jobs)
# -----------------------------------------------------
QSTASH_URL="https://qstash.upstash.io/v2"
QSTASH_TOKEN=""
QSTASH_CURRENT_SIGNING_KEY=""
QSTASH_NEXT_SIGNING_KEY=""
CRON_SECRET="change-me"

# -----------------------------------------------------
# Telegram webhook/channel
# -----------------------------------------------------
TELEGRAM_BOT_TOKEN=""
TELEGRAM_WEBHOOK_SECRET=""
TELEGRAM_BOT_USERNAME=""
TELEGRAM_SYNC_WEBHOOK="false"
TELEGRAM_DISABLE_AI="false"
TELEGRAM_DISABLE_SEND="false"

# -----------------------------------------------------
# WhatsApp webhook/channel
# -----------------------------------------------------
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_APP_SECRET=""
WHATSAPP_VERIFY_TOKEN=""
WHATSAPP_SYNC_WEBHOOK="false"
WHATSAPP_DISABLE_AI="false"
WHATSAPP_DISABLE_SEND="false"

# -----------------------------------------------------
# Voice (ElevenLabs)
# -----------------------------------------------------
ELEVENLABS_API_KEY=""
ELEVENLABS_VOICE_ID=""
ELEVENLABS_FLASH_COST_USD_PER_1000_CHARACTERS="0.05"

# -----------------------------------------------------
# Analytics (PostHog)
# -----------------------------------------------------
POSTHOG_API_KEY=""
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"

# -----------------------------------------------------
# Optional debug flags
# -----------------------------------------------------
LOG_PRISMA_QUERIES="false"
ENABLE_LATENCY_LOGS="false"
APP_LOG_LEVEL="info"
APP_LOG_FORMAT="pretty"
APP_LOG_COLORS="true"
APP_LOG_DOMAIN_LEVELS=""
APP_LOG_EXCLUDE_EVENTS=""
