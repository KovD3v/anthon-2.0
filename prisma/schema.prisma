// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// -----------------------------------------------------
// USER ROLES
// -----------------------------------------------------

enum UserRole {
  USER
  ADMIN
  SUPER_ADMIN
}

// -----------------------------------------------------
// USER (identità unica cross-canale)
// -----------------------------------------------------

model User {
  id String @id @default(cuid())

  // Authentication - Clerk integration for web chat
  clerkId String? @unique
  email   String? @unique

  // Guest / anonymous mode
  // Guest users can chat before registering; they should NOT get the full trial.
  isGuest          Boolean   @default(false)
  guestAbuseIdHash String?   @unique // e.g. hash of phone number or other identifier
  guestConvertedAt DateTime? // set when the guest account is merged/converted

  // Role-based access control
  role UserRole @default(USER)

  // Relationships
  profile                     Profile?
  preferences                 Preferences?
  memories                    Memory[]
  messages                    Message[]
  chats                       Chat[]
  conversationThreads         ConversationThread[]
  aiTurnTraces                AiTurnTrace[]
  dailyUsage                  DailyUsage[]
  identities                  ChannelIdentity[]
  consumedLinkTokens          ChannelLinkToken[]           @relation("ChannelLinkTokenConsumedBy")
  subscription                Subscription?
  sessionSummaries            SessionSummary[]
  archivedSessions            ArchivedSession[]
  voiceUsage                  VoiceUsage[]
  voiceGenerationJobs         VoiceGenerationJob[]
  organizationMemberships     OrganizationMembership[]
  ownedOrganizations          Organization[]               @relation("OrganizationOwner")
  createdOrganizations        Organization[]               @relation("OrganizationCreator")
  organizationAuditLogs       OrganizationAuditLog[]       @relation("OrganizationAuditActor")
  modelExperimentParticipants ModelExperimentParticipant[]
  modelExperimentPairs        ModelExperimentPair[]
  modelExperimentAudits       ModelExperimentAudit[]       @relation("ModelExperimentAuditActor")
  createdModelExperiments     ModelExperiment[]            @relation("ModelExperimentCreator")

  billingSyncedAt DateTime?
  lastActivityAt  DateTime  @default(now())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime? // Soft delete

  @@index([role])
  @@index([isGuest])
  @@index([deletedAt])
  @@index([lastActivityAt])
  @@index([billingSyncedAt])
}

// -----------------------------------------------------
// ORGANIZATIONS (B2B tenancy via Clerk Organizations)
// -----------------------------------------------------

enum OrganizationStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum OrganizationModelTier {
  TRIAL
  BASIC
  BASIC_PLUS
  PRO
  ENTERPRISE
  ADMIN
}

enum OrganizationBasePlan {
  BASIC
  BASIC_PLUS
  PRO
}

enum OrganizationMemberRole {
  OWNER
  MEMBER
}

enum OrganizationMembershipStatus {
  ACTIVE
  REMOVED
  BLOCKED
}

enum OrganizationAuditActorType {
  ADMIN
  SYSTEM
  WEBHOOK
}

enum OrganizationAuditAction {
  ORGANIZATION_CREATED
  CONTRACT_UPDATED
  OWNER_ASSIGNED
  OWNER_TRANSFERRED
  MEMBERSHIP_SYNCED
  MEMBERSHIP_BLOCKED_SEAT_LIMIT
}

model Organization {
  id String @id @default(cuid())

  clerkOrganizationId String             @unique
  name                String
  slug                String             @unique
  status              OrganizationStatus @default(ACTIVE)

  ownerUserId String?
  ownerUser   User?   @relation("OrganizationOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)

  pendingOwnerEmail String?

  createdByUserId String
  createdByUser   User   @relation("OrganizationCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)

  contract    OrganizationContract?
  memberships OrganizationMembership[]
  auditLogs   OrganizationAuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([ownerUserId])
  @@index([createdByUserId])
}

model OrganizationContract {
  id String @id @default(cuid())

  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  basePlan  OrganizationBasePlan  @default(BASIC)
  seatLimit Int
  planLabel String
  modelTier OrganizationModelTier @default(BASIC)

  maxRequestsPerDay     Int
  maxInputTokensPerDay  Int
  maxOutputTokensPerDay Int
  maxCostPerDay         Float
  maxContextMessages    Int

  version Int @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([basePlan])
  @@index([modelTier])
}

model OrganizationMembership {
  id String @id @default(cuid())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  clerkMembershipId String                       @unique
  role              OrganizationMemberRole       @default(MEMBER)
  status            OrganizationMembershipStatus @default(ACTIVE)

  joinedAt DateTime?
  leftAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, userId])
  @@index([organizationId, status])
  @@index([userId, status])
  @@index([role])
}

model OrganizationAuditLog {
  id String @id @default(cuid())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  actorUserId String?
  actorUser   User?   @relation("OrganizationAuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  actorType OrganizationAuditActorType
  action    OrganizationAuditAction
  before    Json?
  after     Json?
  metadata  Json?

  createdAt DateTime @default(now())

  @@index([organizationId, createdAt(sort: Desc)])
  @@index([action, createdAt(sort: Desc)])
  @@index([actorUserId])
}

// -----------------------------------------------------
// CHANNEL IDENTITY (una identità per ogni canale: es. WhatsApp=numero telefono)
// -----------------------------------------------------

model ChannelIdentity {
  id String @id @default(cuid())

  channel    Channel @default(WHATSAPP)
  externalId String // e.g.: WhatsApp phone number, Telegram user ID, Instagram PSID

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([channel, externalId])
  @@index([userId])
  @@index([channel])
}

// -----------------------------------------------------
// CHANNEL LINK TOKENS (one-time linking flow)
// -----------------------------------------------------

model ChannelLinkToken {
  id String @id @default(cuid())

  channel   Channel
  tokenHash String  @unique

  // External identity to link (e.g. Telegram user id)
  externalId String
  chatId     String

  expiresAt  DateTime
  consumedAt DateTime?

  consumedByUserId String?
  consumedByUser   User?   @relation("ChannelLinkTokenConsumedBy", fields: [consumedByUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([channel, externalId])
  @@index([expiresAt])
}

// -----------------------------------------------------
// CONNECT COMMAND DELIVERY (retry-safe channel linking)
// -----------------------------------------------------

enum ChannelConnectResponseKind {
  LINK
  ALREADY_LINKED
  UNAVAILABLE
}

enum ChannelConnectDeliveryStatus {
  PENDING
  SENDING
  SENT
  FAILED
}

// A provider message can be delivered more than once. This marker owns the
// one-time link-token creation and the outbound response delivery lifecycle.
model ChannelConnectRequest {
  id String @id @default(cuid())

  channel           Channel
  externalMessageId String
  externalId        String
  chatId            String
  responseKind      ChannelConnectResponseKind

  status                 ChannelConnectDeliveryStatus @default(PENDING)
  claimToken             String?
  deliveryLeaseExpiresAt DateTime?
  deliveryAttempts       Int                          @default(0)
  deliveredAt            DateTime?
  lastDeliveryError      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([channel, externalMessageId])
  @@index([status, deliveryLeaseExpiresAt])
}

enum Channel {
  WEB
  WHATSAPP
  TELEGRAM
  // FUTURE: TELEGRAM, INSTAGRAM, MESSENGER, EMAIL, IOS_APP, ANDROID_APP
}

enum ExternalInboundProcessingStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// -----------------------------------------------------
// CHAT (conversation sessions)
// -----------------------------------------------------

enum ChatVisibility {
  PRIVATE
  PUBLIC
}

model Chat {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  title       String? // Auto-generated or user-provided
  customTitle Boolean        @default(false)
  visibility  ChatVisibility @default(PRIVATE)

  messages             Message[]
  artifacts            Artifact[]
  conversationThread   ConversationThread?
  modelExperimentPairs ModelExperimentPair[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // Soft delete

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, updatedAt(sort: Desc)])
  @@index([visibility])
  @@index([deletedAt])
}

// -----------------------------------------------------
// MESSAGE (supporta testo, media, template, location, audio, ecc.)
// -----------------------------------------------------

model Message {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Chat reference (for multi-chat support)
  chatId String?
  chat   Chat?   @relation(fields: [chatId], references: [id], onDelete: Cascade)

  // Stable conversation scope. New writes must always populate this, while
  // the nullable relation keeps legacy messages migratable.
  conversationThreadId String?
  conversationThread   ConversationThread? @relation(fields: [conversationThreadId], references: [id], onDelete: Cascade)

  channel   Channel          @default(WHATSAPP)
  direction MessageDirection
  role      MessageRole

  // Message content and media
  type  MessageType @default(TEXT)
  parts Json? // AI SDK v5 message parts format

  mediaUrl  String? // Media URL: images, audio, video, documents, stickers
  mediaType String? // MIME type e.g.: image/jpeg, audio/ogg

  externalMessageId String? // External message ID from WhatsApp/Telegram/Instagram
  metadata          Json? // Dynamic payload (location, template params, button events, etc.)

  externalInboundStatus         ExternalInboundProcessingStatus?
  externalInboundClaimToken     String?
  externalInboundLeaseExpiresAt DateTime?
  externalInboundAttempts       Int?
  externalInboundCompletedAt    DateTime?
  externalInboundLastError      String?

  // -----------------------------------------------------
  // AI TRACKING (for ASSISTANT messages only)
  // -----------------------------------------------------
  model            String? // e.g.: "x-ai/grok-4.1-fast:free", "google/gemini-2.5-flash"
  inputTokens      Int? // Input tokens (prompt)
  outputTokens     Int? // Output tokens generated
  reasoningTokens  Int? // Reasoning tokens (for models that support it)
  reasoningContent String? // Reasoning process content
  toolCalls        Json? // Array of tool calls made [{name, args, result}]
  ragUsed          Boolean? @default(false) // Whether RAG was used for this response
  ragChunksCount   Int? // Number of RAG chunks used
  costUsd          Float? // Cost in USD for this response
  generationTimeMs Int? // Total generation time in ms
  reasoningTimeMs  Int? // Reasoning time in ms (if available)
  feedback         Int? // User feedback: -1 = negative, 0 = neutral, 1 = positive

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // Soft delete

  // Relationships
  attachments                  Attachment[]
  artifacts                    Artifact[]            @relation("MessageArtifacts")
  metrics                      MessageMetrics?
  voiceGenerationJob           VoiceGenerationJob?
  sourceModelExperimentPairs   ModelExperimentPair[] @relation("ModelExperimentSourceMessage")
  canonicalModelExperimentPair ModelExperimentPair?  @relation("ModelExperimentCanonicalMessage")

  @@unique([channel, externalMessageId])
  @@index([userId, channel, createdAt])
  @@index([userId, createdAt(sort: Desc)])
  @@index([chatId, createdAt])
  @@index([chatId, userId, createdAt(sort: Desc)])
  @@index([conversationThreadId, createdAt])
  @@index([externalMessageId])
  @@index([externalInboundStatus, externalInboundLeaseExpiresAt])
  @@index([userId, role, createdAt])
  @@index([model, createdAt])
  @@index([deletedAt])
}

// -----------------------------------------------------
// CONVERSATION THREAD (raw history is never cross-channel)
// -----------------------------------------------------

model ConversationThread {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  channel          Channel
  externalThreadId String

  // Web chats map one-to-one to a thread. External channels use their stable
  // platform thread identifier and intentionally leave this empty.
  chatId String? @unique
  chat   Chat?   @relation(fields: [chatId], references: [id], onDelete: Cascade)

  messages             Message[]
  summary              ConversationThreadSummary?
  traces               AiTurnTrace[]
  modelExperimentPairs ModelExperimentPair[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, channel, externalThreadId])
  @@index([userId, channel, updatedAt(sort: Desc)])
}

// -----------------------------------------------------
// PAIRED MODEL COMPARISON EXPERIMENTS
// -----------------------------------------------------

enum ModelExperimentStatus {
  DRAFT
  READY
  ACTIVE
  PAUSED
  COMPLETED
}

enum ModelExperimentVariantRole {
  CONTROL
  CANDIDATE
}

enum ModelExperimentNoticeState {
  NOT_SHOWN
  SHOWN
}

enum ModelExperimentPairStatus {
  GENERATING
  READY
  RESOLVED
  PARTIAL_FAILED
  FAILED
  EXPIRED
}

enum ModelExperimentVote {
  A
  B
  TIE
  AUTO_CONTROL
  AUTO_SUCCESS
}

enum ModelExperimentResponseStatus {
  PENDING
  STREAMING
  COMPLETED
  FAILED
  PURGED
}

model ModelExperiment {
  id String @id @default(cuid())

  key            String                @unique
  name           String
  status         ModelExperimentStatus @default(DRAFT)
  posthogFlagKey String
  targetCountry  String                @default("IT") @db.VarChar(2)
  cooldownHours  Int                   @default(24)
  perUserCap     Int                   @default(5)

  createdByAdminId String
  createdByAdmin   User   @relation("ModelExperimentCreator", fields: [createdByAdminId], references: [id], onDelete: Restrict)

  readyAt     DateTime?
  activatedAt DateTime?
  pausedAt    DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  variants     ModelExperimentVariant[]
  participants ModelExperimentParticipant[]
  pairs        ModelExperimentPair[]
  audits       ModelExperimentAudit[]

  @@index([status])
  @@index([createdAt(sort: Desc)])
}

model ModelExperimentVariant {
  id String @id @default(cuid())

  experimentId String
  experiment   ModelExperiment @relation(fields: [experimentId], references: [id], onDelete: Cascade)

  role             ModelExperimentVariantRole
  modelId          String
  provider         String                     @default("openrouter")
  generationConfig Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  responses       ModelExperimentResponse[]
  pairSlotA       ModelExperimentPair[]     @relation("ModelExperimentSlotA")
  pairSlotB       ModelExperimentPair[]     @relation("ModelExperimentSlotB")
  selectedInPairs ModelExperimentPair[]     @relation("ModelExperimentSelectedVariant")

  @@unique([experimentId, role])
  @@index([modelId])
}

model ModelExperimentParticipant {
  id String @id @default(cuid())

  experimentId String
  experiment   ModelExperiment @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  userId       String
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  noticeState          ModelExperimentNoticeState @default(NOT_SHOWN)
  attempts             Int                        @default(0)
  completedComparisons Int                        @default(0)
  nextEligibleAt       DateTime?
  enrolledAt           DateTime                   @default(now())
  lastExposedAt        DateTime?
  createdAt            DateTime                   @default(now())
  updatedAt            DateTime                   @updatedAt

  pairs ModelExperimentPair[]

  @@unique([experimentId, userId])
  @@index([userId])
  @@index([experimentId, nextEligibleAt])
}

model ModelExperimentPair {
  id String @id @default(cuid())

  experimentId         String
  experiment           ModelExperiment            @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  participantId        String
  participant          ModelExperimentParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  userId               String
  user                 User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  chatId               String
  chat                 Chat                       @relation(fields: [chatId], references: [id], onDelete: Cascade)
  conversationThreadId String
  conversationThread   ConversationThread         @relation(fields: [conversationThreadId], references: [id], onDelete: Cascade)
  sourceMessageId      String                     @unique
  sourceMessage        Message                    @relation("ModelExperimentSourceMessage", fields: [sourceMessageId], references: [id], onDelete: Cascade)

  slotAVariantId String
  slotAVariant   ModelExperimentVariant @relation("ModelExperimentSlotA", fields: [slotAVariantId], references: [id], onDelete: Restrict)
  slotBVariantId String
  slotBVariant   ModelExperimentVariant @relation("ModelExperimentSlotB", fields: [slotBVariantId], references: [id], onDelete: Restrict)

  status             ModelExperimentPairStatus @default(GENERATING)
  vote               ModelExperimentVote?
  selectedVariantId  String?
  selectedVariant    ModelExperimentVariant?   @relation("ModelExperimentSelectedVariant", fields: [selectedVariantId], references: [id], onDelete: Restrict)
  canonicalMessageId String?                   @unique
  canonicalMessage   Message?                  @relation("ModelExperimentCanonicalMessage", fields: [canonicalMessageId], references: [id], onDelete: SetNull)
  countryCode        String                    @db.VarChar(2)
  promptMode         String?
  exposedAt          DateTime?
  readyAt            DateTime?
  resolvedAt         DateTime?
  expiresAt          DateTime
  contentPurgeAt     DateTime?
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt

  responses ModelExperimentResponse[]

  @@index([experimentId, status])
  @@index([participantId, createdAt(sort: Desc)])
  @@index([userId, status])
  @@index([expiresAt])
  @@index([contentPurgeAt])
}

model ModelExperimentResponse {
  id String @id @default(cuid())

  pairId    String
  pair      ModelExperimentPair    @relation(fields: [pairId], references: [id], onDelete: Cascade)
  variantId String
  variant   ModelExperimentVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)

  status             ModelExperimentResponseStatus @default(PENDING)
  parts              Json?
  text               String?                       @db.Text
  provider           String
  modelId            String
  generationConfig   Json
  traceId            String                        @unique
  errorCode          String?
  inputTokens        Int?
  outputTokens       Int?
  reasoningTokens    Int?
  costUsd            Float?
  timeToFirstTokenMs Int?
  generationTimeMs   Int?
  firstTokenAt       DateTime?
  completedAt        DateTime?
  createdAt          DateTime                      @default(now())
  updatedAt          DateTime                      @updatedAt

  @@unique([pairId, variantId])
  @@index([variantId, status])
  @@index([pairId, status])
}

model ModelExperimentAudit {
  id String @id @default(cuid())

  experimentId String
  experiment   ModelExperiment @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  actorUserId  String
  actor        User            @relation("ModelExperimentAuditActor", fields: [actorUserId], references: [id], onDelete: Cascade)
  action       String
  before       Json?
  after        Json?
  createdAt    DateTime        @default(now())

  @@index([experimentId, createdAt(sort: Desc)])
  @@index([actorUserId, createdAt(sort: Desc)])
}

model ConversationThreadSummary {
  id String @id @default(cuid())

  conversationThreadId String             @unique
  conversationThread   ConversationThread @relation(fields: [conversationThreadId], references: [id], onDelete: Cascade)

  summary                 String    @db.Text
  throughMessageId        String?
  throughMessageCreatedAt DateTime?
  version                 Int       @default(1)
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
}

enum AiTurnTraceStatus {
  PENDING
  COMPLETE
  FAILED
}

model AiTurnTrace {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  conversationThreadId String
  conversationThread   ConversationThread @relation(fields: [conversationThreadId], references: [id], onDelete: Cascade)

  userMessageId      String?
  assistantMessageId String?
  status             AiTurnTraceStatus @default(PENDING)
  metadata           Json

  payloadCiphertext    Bytes?
  payloadIv            Bytes?
  payloadTag           Bytes?
  keyVersion           Int    @default(1)
  contentCaptureStatus String @default("pending")

  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accessAudits AiTraceAccessAudit[]

  @@index([conversationThreadId, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@index([expiresAt])
  @@index([userMessageId])
}

model AiTraceAccessAudit {
  id String @id @default(cuid())

  traceId String
  trace   AiTurnTrace @relation(fields: [traceId], references: [id], onDelete: Cascade)

  actorUserId String
  action      String
  createdAt   DateTime @default(now())

  @@index([traceId, createdAt(sort: Desc)])
  @@index([actorUserId, createdAt(sort: Desc)])
}

model MessageMetrics {
  id String @id @default(cuid())

  messageId String  @unique
  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  model    String?
  provider String?

  inputTokens     Int?
  outputTokens    Int?
  totalTokens     Int?
  reasoningTokens Int?

  costUsd          Float?
  generationTimeMs Int?
  reasoningTimeMs  Int?

  toolCallCount   Int?
  toolResultChars Int?
  toolTiming      Json?

  ragUsed        Boolean?
  ragChunksCount Int?

  providerMetadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([model, createdAt])
  @@index([provider, createdAt])
  @@index([createdAt])
}

enum MessageDirection {
  INBOUND // utente → Anthon
  OUTBOUND // Anthon → utente
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum MessageType {
  TEXT
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
  STICKER
  TEMPLATE
  LOCATION
  CONTACT
  UNKNOWN
}

// -----------------------------------------------------
// PROFILE (informazioni di coaching dell’utente)
// -----------------------------------------------------

model Profile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // User coaching information
  name       String?
  sport      String?
  goal       String?
  experience String?
  birthday   DateTime?
  notes      String?   @db.Text // Use TEXT for potentially long notes

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// -----------------------------------------------------
// PREFERENCES (tono, stile, lingua, notifiche)
// -----------------------------------------------------

model Preferences {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tone         String? // e.g.: "calm", "energetic", "professional"
  mode         String? // e.g.: "coaching", "friendly", "direct"
  language     String?  @default("IT") // IT, EN, etc.
  push         Boolean? @default(true) // Push notifications enabled by default
  voiceEnabled Boolean? @default(true) // Voice messages enabled (false = Quiet Mode)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// -----------------------------------------------------
// MEMORY (memoria persistente condivisa tra tutti i canali)
// -----------------------------------------------------

model Memory {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  key      String
  value    Json
  category String @default("other")

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([userId, key])
  @@index([userId, category])
}

// -----------------------------------------------------
// SESSION SUMMARY (persistent cache for session summaries)
// -----------------------------------------------------

model SessionSummary {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  sessionId String @unique // Composite of start/end timestamps
  summary   String @db.Text

  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([userId])
  @@index([expiresAt])
}

// -----------------------------------------------------
// ARCHIVED SESSION (long-term storage of summarized sessions)
// -----------------------------------------------------

model ArchivedSession {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  startDate DateTime
  endDate   DateTime
  summary   String   @db.Text

  // Metrics preserved from the session
  messageCount Int

  createdAt DateTime @default(now())

  @@index([userId, startDate])
}

// -----------------------------------------------------
// RAG DOCUMENTS (Metodo Sincro, PDF, ecc.)
// -----------------------------------------------------

model RagDocument {
  id     String  @id @default(cuid())
  title  String
  url    String?
  source String? // Source identifier (e.g., "training_manual", "knowledge_base")

  chunks RagChunk[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([source])
}

// -----------------------------------------------------
// RAG CHUNKS (embedding pgvector)
// -----------------------------------------------------

model RagChunk {
  id         String      @id @default(cuid())
  documentId String
  document   RagDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  content   String                       @db.Text
  embedding Unsupported("vector(1536)")?
  index     Int // Chunk sequence number within document

  createdAt DateTime @default(now())
  // Note: Vector index is created via raw SQL migration (HNSW index)
  // See: prisma/migrations/20251202120000_fix_vector_index/migration.sql

  @@index([documentId])
  @@index([documentId, index])
}

